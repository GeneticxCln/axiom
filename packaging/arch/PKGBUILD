# Maintainer: Axiom Contributors <axiom@example.com>
pkgname=axiom-compositor-git
pkgver=0.1.0.r$(git rev-list --count HEAD).$(git rev-parse --short HEAD)
pkgrel=1
pkgdesc="Winit-only Wayland compositor with niri-inspired scrollable workspaces (GLES rendering)"
arch=('x86_64')
url="https://github.com/GeneticxCln/axiom"
license=('GPL3')
depends=(
    'wayland'
    'libxkbcommon'
    'mesa'
)
makedepends=(
    'rust'
    'cargo'
    'git'
    'wayland-protocols'
    'pkgconf'
)
optdepends=(
    'xorg-xwayland: X11 application support (via host compositor)'
)
provides=('axiom-compositor')
conflicts=('axiom-compositor')
source=("git+https://github.com/GeneticxCln/axiom.git")
md5sums=('SKIP')

pkgver() {
    cd "$srcdir/axiom"
    printf "0.1.0.r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
    cd "$srcdir/axiom"
    cargo fetch --locked --target "$CARCH-unknown-linux-gnu"
}

build() {
    cd "$srcdir/axiom"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release
}

check() {
    cd "$srcdir/axiom"
    cargo test --frozen
}

package() {
    cd "$srcdir/axiom"

    install -Dm755 "target/release/axiom" "$pkgdir/usr/bin/axiom"
    install -Dm755 "packaging/axiom-session" "$pkgdir/usr/bin/axiom-session"

    # Example nested launcher desktop entry
    install -Dm644 "packaging/axiom.desktop" "$pkgdir/usr/share/applications/axiom.desktop"

    # Session entry for display managers / manual session launchers
    install -Dm644 "packaging/axiom-wayland.desktop" "$pkgdir/usr/share/wayland-sessions/axiom.desktop"

    # Shared app icon used by the nested desktop entry and session file
    install -Dm644 "assets/logo.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/axiom.svg"

    install -Dm644 "config/axiom.toml" "$pkgdir/usr/share/axiom/axiom.toml"
    install -Dm644 "config/axiom.toml" "$pkgdir/etc/axiom/axiom.toml"

    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
